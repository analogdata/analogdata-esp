# analogdata-esp environment variables
# Copy to .env and fill in values, or export directly in ~/.zshrc

# Gemini API key — used as cloud fallback when Ollama is not running
# Get free key at: https://aistudio.google.com
GEMINI_API_KEY=

# Optional: override Ollama base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: override Gemma model (default: gemma3:4b)
# GEMMA_MODEL=gemma3:4b
